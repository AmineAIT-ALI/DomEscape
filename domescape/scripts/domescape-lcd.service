[Unit]
Description=DomEscape LCD Service (PiFace)
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/html/domescape/scripts
ExecStart=/usr/bin/python3 /var/www/html/domescape/scripts/lcd_service.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
